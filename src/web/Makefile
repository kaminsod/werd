.PHONY: dev build test lint typecheck clean generate-types

dev: ## Run dev server
	npm run dev

build: ## Production build
	npm run build

test: ## Run tests
	npm test

lint: ## Run linter
	npm run lint

typecheck: ## Type-check without emitting
	npm run typecheck

generate-types: ## Generate API types from OpenAPI spec
	npm run generate-types

clean: ## Remove build artifacts
	rm -rf dist .vite
