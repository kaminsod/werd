# Werd — Production Caddyfile
# Subdomain routing with automatic TLS via Let's Encrypt.
# Replace {$WERD_DOMAIN} with your domain or set it as an environment variable.

werd.{$WERD_DOMAIN} {
	reverse_proxy werd-dashboard:3000
}

api.{$WERD_DOMAIN} {
	reverse_proxy werd-api:8090
}

