# ── Email Verification Server ──
# Standalone Mailpit instance for receiving platform verification emails.
# DNS MX for EMAIL_DOMAIN must point to this server's IP.

# ── Server ──
SMTP_PORT=25                           # Host port for inbound SMTP
API_PORT=8025                          # Host port for Web UI + REST API

# ── Mailpit ──
MP_MAX_MESSAGES=5000                   # Max stored messages before oldest are pruned
# MP_UI_AUTH=admin:changeme            # Uncomment for basic auth on Web UI (production)

# ── Deploy Target ──
DEPLOY_HOST=165.232.136.251            # VPS IP where Mailpit runs
DEPLOY_USER=root                       # SSH user for deployment
DEPLOY_DIR=/opt/email-verification     # Remote install path
