# ── Domain & Access Mode ──
WERD_DOMAIN=yourdomain.com
WERD_EMAIL=admin@yourdomain.com
WERD_ACCESS_MODE=cloud                  # cloud | residential | local

# ── Residential Tunnel (only if WERD_ACCESS_MODE=residential) ──
# FRP_SERVER_ADDR=relay-vps.example.com
# FRP_SERVER_PORT=7000
# FRP_TOKEN=

# ── Werd API ──
WERD_API_PORT=8090

# ── Database ──
POSTGRES_PASSWORD=changeme

# ── Redis ──
REDIS_PASSWORD=changeme

# ── Service Secrets ──
WERD_JWT_SECRET=changeme
POSTIZ_JWT_SECRET=changeme
ACTIVEPIECES_ENCRYPTION_KEY=changeme
MATTERMOST_SECRET=changeme
PLAUSIBLE_SECRET=changeme

# ── Platform API Keys (configure per project via Dashboard) ──
# Instance-wide OAuth app credentials:
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
# TWITTER_CLIENT_ID=
# TWITTER_CLIENT_SECRET=
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=

# ── Optional: LLM for AI-assisted drafting ──
# LLM_API_URL=
# LLM_API_KEY=
# LLM_MODEL=

# ── Initial Admin Account ──
WERD_ADMIN_EMAIL=admin@yourdomain.com
WERD_ADMIN_PASSWORD=changeme
