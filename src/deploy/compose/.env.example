# ── Domain & Access Mode ──
WERD_DOMAIN=yourdomain.com
WERD_EMAIL=admin@yourdomain.com
WERD_ACCESS_MODE=cloud                  # cloud | residential | local

# ── Residential Tunnel (only if WERD_ACCESS_MODE=residential) ──
# FRP_SERVER_ADDR=relay-vps.example.com
# FRP_SERVER_PORT=7000
# FRP_TOKEN=

# ── Werd API ──
WERD_API_PORT=8090

# ── Database (werd superuser — owns werd DB, runs migrations) ──
POSTGRES_PASSWORD=changeme
# POSTGRES_PORT=5432                    # Uncomment to expose PostgreSQL on host for dev

# ── Per-Service Database Passwords ──
# Each service gets its own PostgreSQL user restricted to its own database.
UMAMI_DB_PASSWORD=changeme

# ── Redis ──
REDIS_PASSWORD=changeme
# REDIS_PORT=6379                      # Uncomment to expose Redis on host for dev

# ── Service Secrets ──
WERD_JWT_SECRET=changeme
WERD_INTERNAL_API_KEY=changeme
WERD_NTFY_URL=http://ntfy:80

# ── Browser Automation (enables browser-based platform interactions) ──
BROWSER_SERVICE_URL=http://browser-service:8091
# BROWSER_PROXY=                       # Optional SOCKS proxy, e.g. socks5://proxy:1080

# ── Platform API Keys (configure per project via Dashboard) ──
# Instance-wide OAuth app credentials:
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=werd-monitor-reddit/1.0
# TWITTER_CLIENT_ID=
# TWITTER_CLIENT_SECRET=
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=

# ── Reddit Monitor ──
# REDDIT_MONITOR_PROJECT_ID=           # UUID of the project to tag alerts with
# REDDIT_MONITOR_SUBREDDITS=golang,selfhosted
# REDDIT_POLL_INTERVAL=60s

# ── HN Monitor ──
# HN_MONITOR_PROJECT_ID=               # UUID of the project to tag alerts with
# HN_MONITOR_KEYWORDS=                 # Optional comma-separated pre-filter keywords
# HN_POLL_INTERVAL=60s

# ── Optional: LLM for AI-assisted classification & drafting ──
# WERD_LLM_API_URL=
# WERD_LLM_API_KEY=
# WERD_LLM_MODEL=

# ── Initial Admin Account ──
WERD_ADMIN_EMAIL=admin@yourdomain.com
WERD_ADMIN_PASSWORD=changeme
